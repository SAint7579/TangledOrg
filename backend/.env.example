# ATProto / Tangled PDS
# The org owner's handle and app password — all shared org data (repos,
# policies, members, incidents, etc.) is read from and written to this
# account's PDS repo so that every org member sees the same data.
TANGLED_ORG_PDS_HOST=https://tngl.sh
TANGLED_ORG_HANDLE=yourhandle.tngl.sh
TANGLED_ORG_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Anthropic (needed for compliance agent, not needed for data models / ATProto testing)
# TANGLED_ORG_ANTHROPIC_API_KEY=sk-ant-...

# AppView
TANGLED_ORG_PORT=8080
TANGLED_ORG_DB_PATH=./data/tangledorg.db

# URLs (set BACKEND_URL to your Railway URL in production)
# TANGLED_ORG_BACKEND_URL=https://your-app.railway.app
TANGLED_ORG_FRONTEND_URL=http://localhost:3000
TANGLED_ORG_SESSION_SECRET=change-me-to-a-random-string

# Debug
TANGLED_ORG_DEBUG=true
